# =============================================================================
# 경매퀵 환경변수 예시
# -----------------------------------------------------------------------------
# 사용법:
#   1. 이 파일을 .env.local로 복사
#   2. 각 변수에 실제 값 채우기
#   3. 프로덕션은 Vercel Dashboard → Settings → Environment Variables
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (로컬 dev + 빌드용)
# Dashboard → Project Settings → API 에서 복사
# -----------------------------------------------------------------------------

# 공개 (클라이언트 번들 노출됨)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 비공개 (서버 전용 — RLS 우회 토큰, 절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# -----------------------------------------------------------------------------
# 사이트 URL (metadataBase용)
# 공개 — 로컬 dev: http://localhost:3000, 프로덕션: https://gyeongmaequick.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Vercel Cron 인증 (서버 전용)
# /api/cron/delete-expired-delegations 호출 시 Bearer 토큰으로 검증.
# Vercel은 Cron 호출 시 Authorization: Bearer ${CRON_SECRET} 자동 첨부.
# 권장: openssl rand -hex 32 로 생성한 64자 hex 문자열.
# -----------------------------------------------------------------------------
CRON_SECRET=replace-with-openssl-rand-hex-32


# -----------------------------------------------------------------------------
# 브랜드 / 수임인 정보 (공개 — PDF·풋터·메타에 노출되는 값)
# 사업자등록 완료 후 실제 값으로 교체.
# 모두 NEXT_PUBLIC_ 접두사: src/lib/constants.ts에서 빌드 타임 평가되어
# 클라이언트 번들에 inline됨 (런타임 process.env 접근 없음, 안전).
#
# 브랜드명 변경 절차:
#   1. 이 변수 값 변경 (.env.local 또는 Vercel Dashboard)
#   2. pnpm build 재실행
#   3. 배포 → 모든 페이지/PDF/메타에 일괄 반영
# -----------------------------------------------------------------------------

# 서비스 브랜드명. PDF Author, 메타 title, 풋터, FAQ 등 전반에 사용.
NEXT_PUBLIC_BRAND_NAME=경매퀵

# 공인중개사 등록번호 (사업자등록 후 발급)
NEXT_PUBLIC_AGENT_REGISTRATION_NUMBER=공인중개사 등록번호 미정 (사업자등록 후 갱신)

# 사무소 주소
NEXT_PUBLIC_AGENT_OFFICE_ADDRESS=사무소 주소 미정 (사업자등록 후 갱신)

# 수임인 연락처 (위임장 PDF에 표기)
NEXT_PUBLIC_AGENT_CONTACT=연락처 미정 (사업자등록 후 갱신)

# 개인정보 열람·정정·삭제 요청 연락처 (PDF 경고문, /privacy 등에 표기)
NEXT_PUBLIC_PRIVACY_CONTACT=연락처 준비 중 (사업자등록 후 갱신)

# -----------------------------------------------------------------------------
# 행정안전부 도로명주소 검색 API (server-side / 클라이언트 노출 0)
# data.go.kr 광역 발급 (즉시 + 무료) — Stage 2 cycle 1-A 보강 4
# 사용 영역: /api/address proxy → CaseConfirmModal 광역 AddressSearch
# -----------------------------------------------------------------------------
JUSO_API_KEY=

# -----------------------------------------------------------------------------
# 입금 계좌 정보 (cycle 1-D-A-4-5 신규)
# 사업자등록 사전 (현재 Phase 1) = 미설정 → Step5Payment + Step5Complete = "카카오톡 직접 안내" 단독
# 사업자등록 사후 = 3개 광역 설정 → Step5 입금 안내 카드 광역 자동 render (코드 영역 0)
# NEXT_PUBLIC_ prefix 의무 = client component env 접근 paradigm (Next.js 정합)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BANK_NAME=
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=
NEXT_PUBLIC_BANK_ACCOUNT_HOLDER=
